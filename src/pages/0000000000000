import React, { useState, useEffect } from 'react';
import {
  ArrowRight, Edit, BookMarked, GraduationCap,
  Calendar, CreditCard, FileText, MessageSquare, MapPin, Clock,
  CheckCircle, XCircle, AlertCircle, Award, Download, Trash2,
  Calculator, MessageCircle // تم إضافة أيقونات جديدة
} from 'lucide-react';
import {
  RadarChart, Radar, PolarGrid, PolarAngleAxis, PolarRadiusAxis,
  BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip,
  ResponsiveContainer
} from 'recharts';
import {
  mockQuranRecords, mockInvoices, mockSessions,
  mockEnrollments, mockCertificates, mockTajweedErrors,
  mockQuranProgressData
} from '../data/mockData';
import { StatusBadge } from '../components/shared/StatusBadge';
import { Avatar } from '../components/shared/Avatar';
import {
  formatDateAr, formatCurrency, getSurahName,
  TRACK_TYPE_LABELS, formatRelativeTime
} from '../utils/formatters';
import type { Student } from '../types';
import { StudentFormModal } from '../components/students/StudentFormModal'; 

const TABS = [
  { id: 'overview', label: 'نظرة عامة', icon: GraduationCap },
  { id: 'quran', label: 'تتبع القرآن', icon: BookMarked },
  { id: 'academic', label: 'الأكاديمي', icon: TrendingUp: null }, // سنعوضها أدناه لمنع الأخطاء
  { id: 'attendance', label: 'الحضور', icon: Calendar },
  { id: 'finance', label: 'المالية', icon: CreditCard },
  { id: 'documents', label: 'الوثائق', icon: FileText },
  { id: 'notes', label: 'التواصل', icon: MessageSquare },
];

const StarRating: React.FC<{ score: number }> = ({ score }) => (
  <div className="flex gap-0.5">
    {Array.from({ length: 10 }).map((_, i) => (
      <span key={i} className={`text-base leading-none ${i < score ? 'text-[#F39C12]' : 'text-gray-200'}`}>★</span>
    ))}
    <span className="text-sm font-bold text-gray-600 mr-1">{score}/10</span>
  </div>
);

export const StudentDetailPage: React.FC<{ studentId: string, onBack: () => void, onNavigate: (page: string, id?: string) => void }> = ({ studentId, onBack, onNavigate }) => {
  const [activeTab, setActiveTab] = useState('overview');
  const [student, setStudent] = useState<any>(null); // استخدام any مؤقتاً لتجنب أخطاء TypeScript مع الحقول الجديدة
  const [isLoading, setIsLoading] = useState(true);
  const [showEditModal, setShowEditModal] = useState(false);

  useEffect(() => {
    const fetchStudentDetails = async () => {
      try {
        setIsLoading(true);
        const apiUrl = import.meta.env.VITE_API_URL || 'https://itqan-lms.vercel.app';
        const response = await fetch(`${apiUrl}/students`);
        if (!response.ok) throw new Error('فشل الاتصال بالسيرفر');
        
        const data = await response.json();
        const foundStudent = data.find((s: any) => s.id === studentId);
        setStudent(foundStudent || null);
      } catch (error) {
        console.error("خطأ في جلب تفاصيل الطالب:", error);
      } finally {
        setIsLoading(false);
      }
    };
    fetchStudentDetails();
  }, [studentId]);

  const handleDeleteStudent = async () => {
    if (!window.confirm('هل أنت متأكد من حذف هذا الطالب نهائياً؟')) return;
    try {
      const apiUrl = import.meta.env.VITE_API_URL || 'https://itqan-lms.vercel.app';
      const response = await fetch(`${apiUrl}/students/${studentId}`, { method: 'DELETE' });
      if (!response.ok) throw new Error('فشل الحذف');
      onBack(); 
    } catch (error) {
      alert("حدث خطأ أثناء حذف الطالب.");
    }
  };

  const handleUpdateStudent = async (formData: any) => {
    try {
      const apiUrl = import.meta.env.VITE_API_URL || 'https://itqan-lms.vercel.app';
      const response = await fetch(`${apiUrl}/students/${studentId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData),
      });
      if (!response.ok) throw new Error('فشل التعديل');
      const updatedStudent = await response.json();
      setStudent(updatedStudent);
      setShowEditModal(false);
    } catch (error) {
      alert("حدث خطأ أثناء تحديث البيانات.");
    }
  };

  // ==========================================
  // دالة إرسال رسالة الواتساب التلقائية
  // ==========================================
  const handleSendWhatsApp = () => {
    if(!student) return;
    const msg = `أهلاً بك ${student.nameAr}! 🌸
خطوة مباركة ونسأل الله أن ييسر لك حفظ كتابه ويجعله ربيع قلبك.

تم اعتماد جدولك المبدئي على بركة الله، وإليك تفاصيل اشتراكك:

🗓️ *المسار:* ${student.targetTrack || 'لم يحدد بعد'}
⏰ *الباقة المتفق عليها:* باقة ${student.targetPackage || 'غير محدد'} (${student.daysPerWeek || 0} أيام أسبوعياً)
📅 *مقدار الحفظ لكل حصة:* ${student.memPerSession || 0} وجه
🏁 *تاريخ الختم المتوقع:* خلال ${student.expectedMonths || 0} شهراً بإذن الله
💰 *الاستثمار الشهري:* ${student.monthlyFee || 0}

لتأكيد الاشتراك وتثبيت موعدك، يرجى إتمام سداد الرسوم.
في انتظارك لنبدأ رحلتنا القرآنية 🌷`;

    // توجيه لفتح الواتساب (إذا كان هناك رقم للوالد يستخدمه، وإلا سيفتح الواتساب لاختيار جهة الاتصال)
    const phone = student.parentPhone ? student.parentPhone.replace(/\+/g, '') : '';
    const encodedMsg = encodeURIComponent(msg);
    const waUrl = phone ? `https://wa.me/${phone}?text=${encodedMsg}` : `https://wa.me/?text=${encodedMsg}`;
    
    window.open(waUrl, '_blank');
  };

  if (isLoading) {
    return (
      <div className="flex flex-col items-center justify-center h-[60vh] space-y-4">
        <div className="w-12 h-12 border-4 border-[#1B4F72] border-t-transparent rounded-full animate-spin"></div>
        <p className="text-gray-500 font-medium">جاري جلب ملف الطالب...</p>
      </div>
    );
  }

  if (!student) {
    return (
      <div className="flex flex-col items-center justify-center h-[60vh] space-y-4">
        <AlertCircle size={48} className="text-red-400" />
        <p className="text-gray-800 font-bold text-lg">لم يتم العثور على بيانات الطالب</p>
        <button onClick={onBack} className="btn btn-primary">العودة لقائمة الطلاب</button>
      </div>
    );
  }

  const studentRecords = mockQuranRecords.filter((r) => r.studentId === student.id);
  const totalPagesMemorized = studentRecords.reduce((sum, r) => sum + (r.pagesCount || 0), 0);
  const avgScore = studentRecords.length > 0 ? studentRecords.reduce((s, r) => s + (r.recitationScore || 0), 0) / studentRecords.length : 0;

  return (
    <div className="space-y-4 animate-fadeIn">
      {/* Breadcrumb */}
      <button onClick={onBack} className="flex items-center gap-2 text-gray-500 hover:text-[#1B4F72] transition-colors text-sm font-medium">
        <ArrowRight size={16} /> العودة إلى قائمة الطلاب
      </button>

      {/* Profile Header */}
      <div className="card p-6">
        <div className="flex flex-col md:flex-row gap-5">
          <div className="relative flex-shrink-0">
            <Avatar name={student.nameAr} size="xl" imageUrl={student.profileImageUrl} />
            <button onClick={() => setShowEditModal(true)} className="absolute -bottom-1 -left-1 w-8 h-8 bg-[#1B4F72] rounded-full flex items-center justify-center text-white shadow-lg border-2 border-white">
              <Edit size={14} />
            </button>
          </div>
          <div className="flex-1">
            <div className="flex flex-col md:flex-row md:items-start justify-between gap-4">
              <div>
                <h1 className="text-2xl font-black text-gray-800 mb-1">{student.nameAr}</h1>
                <StatusBadge status={student.status} />
              </div>
              <div className="flex flex-wrap gap-2">
                {/* زر إرسال الخطة واتساب الجديد */}
                <button onClick={handleSendWhatsApp} className="btn btn-sm bg-[#25D366] hover:bg-[#1DA851] text-white gap-2 shadow-md">
                  <MessageCircle size={16} />
                  إرسال الخطة واتساب
                </button>
                <button onClick={() => setShowEditModal(true)} className="btn btn-ghost border border-gray-200 btn-sm gap-1">
                  <Edit size={15} /> تعديل
                </button>
                <button onClick={handleDeleteStudent} className="btn btn-icon btn-ghost btn-sm text-red-500 hover:bg-red-50 tooltip" data-tip="حذف الطالب">
                  <Trash2 size={16} />
                </button>
              </div>
            </div>

            {/* Info Grid */}
            <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mt-5">
              <div className="flex items-center gap-2 text-sm text-gray-500">
                <MapPin size={15} className="text-gray-400" />
                <span>{student.nationality || 'غير محدد'}</span>
              </div>
              {student.parentPhone && (
                <div className="flex items-center gap-2 text-sm text-gray-500" dir="ltr">
                  <MessageCircle size={15} className="text-[#25D366]" />
                  <span>{student.parentPhone}</span>
                </div>
              )}
            </div>
          </div>
        </div>

        {/* Quick Stats */}
        <div className="grid grid-cols-2 md:grid-cols-4 gap-3 mt-6 pt-5 border-t border-gray-100">
          <div className="text-center">
            <p className="text-2xl font-black text-[#1B4F72]">{totalPagesMemorized.toFixed(1)}</p>
            <p className="text-xs text-gray-400 mt-0.5">صفحات محفوظة</p>
          </div>
          <div className="text-center">
            <p className="text-2xl font-black text-[#27AE60]">{avgScore.toFixed(1)}</p>
            <p className="text-xs text-gray-400 mt-0.5">متوسط الدرجات</p>
          </div>
        </div>
      </div>

      {/* Tabs */}
      <div className="tabs-scrollable">
        <div className="tabs bg-white rounded-xl border border-gray-100 px-2 overflow-hidden" style={{ minWidth: 'max-content' }}>
          {TABS.map((tab) => {
            const Icon = tab.icon || GraduationCap;
            return (
              <button key={tab.id} onClick={() => setActiveTab(tab.id)} className={`tab ${activeTab === tab.id ? 'active' : ''}`}>
                <Icon size={15} /> {tab.label}
              </button>
            );
          })}
        </div>
      </div>

      {/* Tab Content */}
      {activeTab === 'overview' && (
        <div className="grid grid-cols-1 lg:grid-cols-2 gap-5 animate-fadeIn">
          
          {/* لوحة التسكين الذكي الجديدة */}
          <div className="card p-5 border-t-4 border-[#F39C12] shadow-sm relative overflow-hidden">
            <div className="absolute top-[-20px] left-[-20px] opacity-5">
              <Calculator size={100} />
            </div>
            <div className="relative z-10">
              <h3 className="font-bold text-gray-800 mb-4 flex items-center gap-2">
                <Calculator size={18} className="text-[#F39C12]" />
                خطة التسكين الذكي
              </h3>
              
              {student.targetTrack ? (
                <div className="space-y-4">
                  <div className="flex items-center justify-between p-3 bg-amber-50 rounded-xl border border-amber-100">
                    <span className="font-bold text-amber-800 text-lg">{student.targetTrack}</span>
                    <span className="text-xs font-bold bg-white text-amber-700 px-2 py-1 rounded-full border border-amber-200">باقة {student.targetPackage}</span>
                  </div>
                  
                  <div className="grid grid-cols-2 gap-3 text-sm">
                    <div className="p-3 bg-gray-50 rounded-lg">
                      <p className="text-gray-500 text-xs mb-1">المدة المتوقعة للختم</p>
                      <p className="font-bold text-[#1B4F72] text-lg">{student.expectedMonths} شهراً</p>
                    </div>
                    <div className="p-3 bg-gray-50 rounded-lg">
                      <p className="text-gray-500 text-xs mb-1">مقدار الحفظ اليومي</p>
                      <p className="font-bold text-[#27AE60] text-lg">{student.memPerSession} وجه</p>
                    </div>
                    <div className="p-3 bg-gray-50 rounded-lg">
                      <p className="text-gray-500 text-xs mb-1">أيام الحضور</p>
                      <p className="font-bold text-gray-800 text-lg">{student.daysPerWeek} أيام/أسبوع</p>
                    </div>
                    <div className="p-3 bg-gray-50 rounded-lg">
                      <p className="text-gray-500 text-xs mb-1">الرسوم الشهرية</p>
                      <p className="font-bold text-gray-800 text-lg">{student.monthlyFee} {student.nationality==='EG'?'ج.م':student.nationality==='SA'?'ر.س':'$'}</p>
                    </div>
                  </div>
                </div>
              ) : (
                <div className="text-center py-6 text-gray-400">
                  <p>لم يتم إجراء تسكين ذكي لهذا الطالب.</p>
                  <button onClick={() => setShowEditModal(true)} className="btn btn-outline btn-sm mt-3 border-[#F39C12] text-[#F39C12] hover:bg-amber-50">
                    إجراء تسكين الآن
                  </button>
                </div>
              )}
            </div>
          </div>

          {/* Recent Sessions */}
          <div className="card p-5">
            <h3 className="font-bold text-gray-800 mb-4">آخر الجلسات</h3>
            <div className="space-y-3">
              {mockSessions.slice(0, 4).map((session) => (
                <div key={session.id} className="flex items-center gap-3 p-2 hover:bg-gray-50 rounded-lg transition-colors">
                  <div className={`w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 ${
                    session.status === 'COMPLETED' ? 'bg-green-100' :
                    session.status === 'CANCELLED' ? 'bg-red-100' : 'bg-blue-100'
                  }`}>
                    {session.status === 'COMPLETED' ? <CheckCircle size={16} className="text-green-600" /> : <Clock size={16} className="text-blue-600" />}
                  </div>
                  <div className="flex-1">
                    <p className="text-sm font-semibold text-gray-700">{session.course?.nameAr}</p>
                    <p className="text-xs text-gray-400">{new Date(session.scheduledAt).toLocaleDateString('ar-SA')}</p>
                  </div>
                  <StatusBadge status={session.status} size="sm" />
                </div>
              ))}
            </div>
          </div>
        </div>
      )}

      {/* باقي التبويبات (نفس الكود القديم للقرآن، المالية... إلخ) يمكن إضافتها هنا لتكتمل الصفحة */}
      {activeTab === 'quran' && (
        <div className="card p-5 text-center text-gray-400 animate-fadeIn">
          <BookMarked size={48} className="mx-auto mb-3 opacity-50" />
          <p>لوحة تتبع القرآن الخاصة بالطالب ستظهر هنا.</p>
        </div>
      )}

      {/* نافذة التعديل */}
      {showEditModal && (
        <StudentFormModal 
          student={student}
          onClose={() => setShowEditModal(false)} 
          onSave={handleUpdateStudent} 
        />
      )}
    </div>
  );
};