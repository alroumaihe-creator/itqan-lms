generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  TEACHER
  ACCOUNTANT
  PARENT
  STUDENT
}

enum StudentStatus {
  LEAD
  TRIAL
  ACTIVE
  SUSPENDED
  GRADUATED
  DROPPED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?  @default("123456")
  role      Role     @default(STUDENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  
  student   Student?
  teacher   Teacher?
}

model Student {
  id              String        @id @default(uuid())
  userId          String        @unique
  nameAr          String
  nameEn          String?
  status          StudentStatus @default(LEAD)
  nationality     String?
  timezone        String        @default("Asia/Riyadh")
  createdAt       DateTime      @default(now())
  
  user            User          @relation(fields: [userId], references: [id])
  enrollments     Enrollment[]  // ربط الطالب باشتراكاته
}

model Teacher {
  id              String   @id @default(uuid())
  userId          String   @unique
  nameAr          String
  nameEn          String?
  specialization  String?
  status          String?  @default("ACTIVE")
  paymentMethod   String?  @default("HOURLY") 
  hourlyRate      Float?
  percentageRate  Float?
  isAvailable     Boolean  @default(true)
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
  enrollments     Enrollment[]  // ربط المعلم بالطلاب المشتركين معه
}

model Course {
  id            String   @id @default(uuid())
  nameAr        String
  nameEn        String?
  type          String
  level         Int      @default(1)
  price         Float?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  enrollments   Enrollment[]  // ربط الدورة بالاشتراكات
}

// ==========================================
// الجدول الجديد: الاشتراكات (Enrollments)
// ==========================================
model Enrollment {
  id          String   @id @default(uuid())
  studentId   String
  courseId    String
  teacherId   String?  // المعلم المسؤول عن تدريس هذا الطالب في هذه الدورة
  progress    Float    @default(0) // نسبة التقدم المئوية
  isActive    Boolean  @default(true)
  enrolledAt  DateTime @default(now())

  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher     Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
}