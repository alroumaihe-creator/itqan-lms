generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  TEACHER
  ACCOUNTANT
  PARENT
  STUDENT
}

enum StudentStatus {
  LEAD
  TRIAL
  ACTIVE
  SUSPENDED
  GRADUATED
  DROPPED
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

// الحالات الجديدة للنظام المالي
enum InvoiceStatus {
  PAID
  UNPAID
  OVERDUE
}

enum SalaryStatus {
  PENDING
  PAID
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?  @default("123456")
  role      Role     @default(STUDENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  
  student   Student?
  teacher   Teacher?
}

model Student {
  id              String        @id @default(uuid())
  userId          String        @unique
  nameAr          String
  nameEn          String?
  status          StudentStatus @default(LEAD)
  nationality     String?
  timezone        String        @default("Asia/Riyadh")
  createdAt       DateTime      @default(now())
  
  user            User          @relation(fields: [userId], references: [id])
  enrollments     Enrollment[]
  quranRecords    QuranRecord[]
  attendances     Attendance[]  
  invoices        Invoice[]     // ربط الطالب بفواتيره
}

model Teacher {
  id              String   @id @default(uuid())
  userId          String   @unique
  nameAr          String
  nameEn          String?
  specialization  String?
  status          String?  @default("ACTIVE")
  paymentMethod   String?  @default("HOURLY") 
  hourlyRate      Float?
  percentageRate  Float?
  isAvailable     Boolean  @default(true)
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
  enrollments     Enrollment[]
  sessions        Session[] 
  salaries        TeacherSalary[] // ربط المعلم بمسير رواتبه
}

model Course {
  id            String   @id @default(uuid())
  nameAr        String
  nameEn        String?
  type          String
  level         Int      @default(1)
  price         Float?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  enrollments   Enrollment[]
  sessions      Session[] 
}

model Enrollment {
  id          String   @id @default(uuid())
  studentId   String
  courseId    String
  teacherId   String?  
  progress    Float    @default(0) 
  isActive    Boolean  @default(true)
  enrolledAt  DateTime @default(now())

  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher     Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
}

model QuranRecord {
  id              String   @id @default(uuid())
  studentId       String
  teacherId       String
  trackType       String   
  surahStart      String
  ayahStart       Int?
  surahEnd        String?
  ayahEnd         Int?
  pagesCount      Float
  recitationScore Float?   
  tajweedErrors   String[] 
  teacherNotes    String?
  createdAt       DateTime @default(now())

  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Session {
  id              String        @id @default(uuid())
  courseId        String
  teacherId       String
  scheduledAt     DateTime      
  durationMinutes Int           @default(60)
  status          SessionStatus @default(SCHEDULED)
  meetingLink     String?       
  notes           String?
  createdAt       DateTime      @default(now())

  course          Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher         Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  attendances     Attendance[]  
}

model Attendance {
  id          String           @id @default(uuid())
  sessionId   String
  studentId   String
  status      AttendanceStatus @default(PRESENT)
  notes       String?
  createdAt   DateTime         @default(now())

  session     Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student     Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId]) 
}

// ==========================================
// النظام المالي (الفواتير والرواتب) بالدولار $
// ==========================================

model Invoice {
  id          String        @id @default(uuid())
  studentId   String
  amount      Float         // المبلغ بالدولار $
  status      InvoiceStatus @default(UNPAID)
  issueDate   DateTime      @default(now())
  dueDate     DateTime
  notes       String?
  createdAt   DateTime      @default(now())

  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model TeacherSalary {
  id              String       @id @default(uuid())
  teacherId       String
  month           Int
  year            Int
  amount          Float        // المبلغ بالدولار $
  status          SalaryStatus @default(PENDING)
  paymentDate     DateTime?
  calculationMode String       // توثيق طريقة الحساب لحظة الصرف (ساعات أو نسبة)
  createdAt       DateTime     @default(now())

  teacher         Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}